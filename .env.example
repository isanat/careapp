# =============================================================================
# CareApp (IdosoLink) - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values
# All variables marked [REQUIRED] must be set for the app to function
# =============================================================================

# --- Database (Turso) ---
# [REQUIRED] Turso database URL
TURSO_DATABASE_URL=libsql://your-database.turso.io
# [REQUIRED] Turso authentication token
TURSO_AUTH_TOKEN=your-turso-auth-token

# --- OR Local SQLite (development only) ---
# DATABASE_URL=file:./db/local.db

# --- Authentication ---
# [REQUIRED] NextAuth secret - generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# [REQUIRED] Full URL of the application
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Wallet Encryption ---
# [REQUIRED] Encryption key for wallet private keys - generate with: openssl rand -base64 32
WALLET_ENCRYPTION_KEY=

# =============================================================================
# PAYMENT PROVIDERS
# =============================================================================

# --- Stripe Payments ---
# Stripe operates in TEST mode by default (keys starting with sk_test_ / pk_test_).
# For production, replace with live keys (sk_live_ / pk_live_).
# Get your test keys at: https://dashboard.stripe.com/test/apikeys
#
# [REQUIRED for payments] Stripe secret key (server-side)
# Test mode: starts with sk_test_
# Production: starts with sk_live_
STRIPE_SECRET_KEY=sk_test_...
#
# [REQUIRED for payments] Stripe publishable key (client-side)
# Test mode: starts with pk_test_
# Production: starts with pk_live_
STRIPE_PUBLISHABLE_KEY=pk_test_...
#
# [REQUIRED for webhooks] Stripe webhook signing secret
# Get from: https://dashboard.stripe.com/test/webhooks
# For local testing use Stripe CLI: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Easypay Payments (Portuguese payment methods: MB Way, Multibanco, etc.) ---
# Easypay sandbox/test environment is enabled by default.
# Set EASYPAY_SANDBOX=false for production.
# Get sandbox credentials at: https://backoffice.test.easypay.pt/
#
# [REQUIRED for Easypay] Enable sandbox/test mode (true = sandbox, false = production)
# Sandbox URL: https://api.test.easypay.pt/2.0
# Production URL: https://api.prod.easypay.pt/2.0
EASYPAY_SANDBOX=true
#
# [REQUIRED for Easypay] Easypay API Key
EASYPAY_API_KEY=
#
# [REQUIRED for Easypay] Easypay Account ID
EASYPAY_ACCOUNT_ID=
#
# [REQUIRED for Easypay webhooks] Easypay webhook secret for signature verification
EASYPAY_WEBHOOK_SECRET=

# =============================================================================
# THIRD-PARTY SERVICES (Optional)
# =============================================================================

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Didit KYC (optional) ---
DIDIT_API_KEY=
DIDIT_API_SECRET=
DIDIT_WEBHOOK_SECRET=
DIDIT_WEBHOOK_URL=

# --- Email (optional - for password reset, notifications) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@idosolink.pt
