# =============================================================================
# CareApp (IdosoLink) - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values
# All variables marked [REQUIRED] must be set for the app to function
# =============================================================================

# --- Database (Turso) ---
# [REQUIRED] Turso database URL
TURSO_DATABASE_URL=libsql://your-database.turso.io
# [REQUIRED] Turso authentication token
TURSO_AUTH_TOKEN=your-turso-auth-token

# --- OR Local SQLite (development only) ---
# DATABASE_URL=file:./db/local.db

# --- Authentication ---
# [REQUIRED] NextAuth secret - generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# [REQUIRED] Full URL of the application
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Wallet Encryption ---
# [REQUIRED] Encryption key for wallet private keys - generate with: openssl rand -base64 32
WALLET_ENCRYPTION_KEY=

# --- Stripe Payments ---
# [REQUIRED for payments] Stripe secret key
STRIPE_SECRET_KEY=sk_test_...
# [REQUIRED for payments] Stripe publishable key
STRIPE_PUBLISHABLE_KEY=pk_test_...
# [REQUIRED for webhooks] Stripe webhook signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Didit KYC (optional) ---
DIDIT_API_KEY=
DIDIT_API_SECRET=
DIDIT_WEBHOOK_SECRET=
DIDIT_WEBHOOK_URL=

# --- Easypay (optional - alternative payment provider) ---
EASYPAY_API_KEY=
EASYPAY_ACCOUNT_ID=
EASYPAY_WEBHOOK_SECRET=

# --- Email (optional - for password reset, notifications) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@idosolink.pt
