// SeniorToken - IdosoLink Platform Schema
// SQLite Database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  FAMILY // Familiar - quem contrata
  CAREGIVER // Cuidador - quem trabalha
  ADMIN // Administrador da plataforma
}

// ==================== ADMIN SYSTEM ====================

enum AdminRole {
  SUPER_ADMIN // Full access, can modify fees, manage admins
  ADMIN // Most operations
  SUPPORT // Read + user support
  MODERATOR // Content moderation only
  ANALYST // Read-only + analytics
}

enum UserStatus {
  PENDING // Cadastro iniciado, aguardando pagamento
  ACTIVE // Ativo, pode usar a plataforma
  SUSPENDED // Suspenso por violação
  INACTIVE // Desativado pelo usuário
}

enum VerificationStatus {
  UNVERIFIED // Não verificado
  PENDING // Em verificação
  VERIFIED // Verificado
  REJECTED // Rejeitado
}

enum PaymentType {
  ACTIVATION // Pagamento de ativação
  CONTRACT_FEE // Taxa de contrato
  SERVICE_PAYMENT // Pagamento de serviço
  VISIBILITY_BOOST // Boost de visibilidade de demanda
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  EASYPAY
  BANK_TRANSFER
  INTERNAL
}

enum ContractStatus {
  DRAFT // Em criação
  PENDING_ACCEPTANCE // Aguardando aceite do cuidador
  PENDING_PAYMENT // Aguardando pagamento
  ACTIVE // Ativo
  COMPLETED // Finalizado
  CANCELLED // Cancelado
  DISPUTED // Em disputa
}

enum ServiceType {
  PERSONAL_CARE // Cuidados pessoais (higiene, banho)
  MEDICATION // Administração de medicação
  MOBILITY // Ajuda com mobilidade
  COMPANIONSHIP // Companhia e conversa
  MEAL_PREPARATION // Preparo de refeições
  LIGHT_HOUSEWORK // Tarefas domésticas leves
  TRANSPORTATION // Transporte para consultas
  COGNITIVE_SUPPORT // Estimulação cognitiva
  NIGHT_CARE // Cuidados noturnos
  PALLIATIVE_CARE // Cuidados paliativos
  PHYSIOTHERAPY // Fisioterapia
  NURSING_CARE // Enfermagem
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum DemandStatus {
  ACTIVE // Demanda ativa, recebendo propostas
  CLOSED // Fechada, contratação feita
  PAUSED // Em pausa, temporariamente inativa
  EXPIRED // Expirada (sem propostas)
}

enum ExperienceLevel {
  BEGINNER // Sem experiência comprovada
  INTERMEDIATE // 1-3 anos de experiência
  ADVANCED // 3-5 anos de experiência
  EXPERT // 5+ anos de experiência
}

enum VisibilityPackage {
  NONE // Sem boost de visibilidade
  BASIC // 7 dias, audiência padrão (€3)
  PREMIUM // 30 dias, destacado (€8)
  URGENT // 3 dias, urgente topo lista (€15)
}

enum CareType {
  URGENT // Necessidade urgente imediata
  RECURRING // Cuidado regular/recorrente
  BOTH // Urgente + recorrente
}

// ==================== USER & PROFILES ====================

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  phone        String? @unique
  name         String
  passwordHash String?

  // Role e Status
  role   UserRole   @default(FAMILY)
  status UserStatus @default(PENDING)

  // Documentos pessoais
  nif            String? // NIF português (9 dígitos)
  documentType   String? // Tipo de documento (CC, Passaporte, etc.)
  documentNumber String? // Número do documento

  // Verificação
  emailVerified      DateTime?
  phoneVerified      DateTime?
  verificationStatus VerificationStatus @default(UNVERIFIED)

  // KYC (Didit)
  kycSessionId        String?
  kycSessionToken     String? // Token for embedded widget
  kycSessionCreatedAt DateTime?
  kycCompletedAt      DateTime?
  kycConfidence       Int       @default(0)
  kycData             String? // Full KYC data JSON from Didit (birthDate, nationality, etc)

  // KYC Document Details (from Didit)
  kycBirthDate          DateTime? // Data de nascimento
  kycNationality        String? // Nacionalidade (BRA, PT, etc)
  kycDocumentIssueDate  DateTime? // Data de emissão
  kycDocumentExpiryDate DateTime? // Data de validade
  kycDocumentIssuer     String? // Órgão emissor

  // Antecedentes criminais
  backgroundCheckStatus String? @default("PENDING") // PENDING, SUBMITTED, VERIFIED, REJECTED
  backgroundCheckUrl    String? // URL do comprovante

  // Metadados
  profileImage      String?
  preferredLanguage String  @default("pt")
  timezone          String  @default("Europe/Lisbon")

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  // Relations
  profileFamily             ProfileFamily?
  profileCaregiver          ProfileCaregiver?
  adminProfile              AdminUser?
  payments                  Payment[]
  contractsAsFamily         Contract[]             @relation("FamilyContracts")
  contractsAsCaregiver      Contract[]             @relation("CaregiverContracts")
  reviewsGiven              Review[]               @relation("ReviewsGiven")
  reviewsReceived           Review[]               @relation("ReviewsReceived")
  chatMessages              ChatMessage[]
  chatParticipations        ChatParticipant[]
  notifications             Notification[]
  sessions                  Session[]
  accounts                  Account[]
  presenceConfirmationScans PresenceConfirmation[] @relation("PresenceConfirmationScans")

  // Demands (Marketplace)
  demandsCreated      Demand[]             @relation("DemandFamily")
  demandViews         DemandView[]         @relation("DemandViewCaregiver")
  demandNotifications DemandNotification[] @relation("DemandNotifications")
  proposalsGiven      Proposal[]           @relation("ProposalsGiven")
}

// Perfil do Familiar (contratante)
model ProfileFamily {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Localização
  address    String?
  city       String?
  postalCode String?
  country    String  @default("PT")
  latitude   Float?
  longitude  Float?

  // Informações do Idoso
  elderName         String?
  elderAge          Int?
  elderNeeds        String? // Descrição das necessidades
  medicalConditions String? // Condições médicas relevantes
  mobilityLevel     String? // Nível de mobilidade

  // Contato de Emergência
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?

  // Preferências
  preferredServices String? // Serviços desejados (JSON array)
  preferredSchedule String? // Horários preferidos (JSON)
  budgetRange       String? // Faixa de orçamento

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Perfil do Cuidador (profissional)
model ProfileCaregiver {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Informações Profissionais
  title           String? // Ex: "Enfermeira", "Cuidadora"
  bio             String? // Descrição pessoal
  experienceYears Int?
  education       String? // Formação acadêmica
  certifications  String? // Certificações (JSON array)
  languages       String? // Idiomas falados (JSON array)

  // Localização e Disponibilidade
  address    String?
  city       String?
  postalCode String?
  country    String  @default("PT")
  latitude   Float?
  longitude  Float?
  radiusKm   Int     @default(20) // Raio de atuação em km

  // Serviços e Preços
  services      String? // Serviços oferecidos (JSON array de ServiceType)
  hourlyRateEur Int     @default(15) // Preço por hora em centavos
  minimumHours  Int     @default(2) // Mínimo de horas por serviço

  // Disponibilidade
  availabilityJson String? // Disponibilidade semanal (JSON)
  availableNow     Boolean @default(false)

  // Verificação
  verificationStatus    VerificationStatus @default(UNVERIFIED)
  documentType          String? // Tipo de documento
  documentNumber        String? // Número do documento
  documentVerified      Boolean            @default(false)
  backgroundCheckStatus String? // Status da verificação de antecedentes

  // KYC Session (Didit)
  kycSessionId        String?
  kycSessionCreatedAt DateTime?
  kycCompletedAt      DateTime?
  kycConfidence       Int       @default(0)

  // Estatísticas
  totalContracts   Int   @default(0)
  totalHoursWorked Int   @default(0)
  averageRating    Float @default(0)
  totalReviews     Int   @default(0)

  // Destaque
  featured Int @default(0) // 0 = não destacado, 1 = destacado

  // Portfolio
  profileImage    String?
  portfolioImages String? // JSON array de URLs

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== PAYMENTS ====================

model Payment {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Tipo e Status
  type     PaymentType
  status   PaymentStatus   @default(PENDING)
  provider PaymentProvider @default(STRIPE)

  // Valores
  amountEurCents Int // Valor em centavos de euro
  platformFee    Int @default(0) // Taxa da plataforma em centavos

  // Stripe
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  stripeCustomerId        String?

  // Referência
  contractId String? // Se for pagamento de contrato
  contract   Contract? @relation(fields: [contractId], references: [id])

  demandId String? // Se for pagamento de visibilidade de demanda
  demand   Demand? @relation(fields: [demandId], references: [id], onDelete: Cascade)

  // Metadata
  description String?
  metadata    String? // JSON adicional (para visibility boost: {"package": "BASIC", "expiresAt": "..."}

  // Approval (para mock/internal payments)
  approvedAt DateTime?
  approvedByAdminId String?

  // Timestamps
  createdAt  DateTime  @default(now())
  paidAt     DateTime?
  refundedAt DateTime?

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([provider, status])
}

// ==================== CONTRACTS ====================

model Contract {
  id String @id @default(cuid())

  // Partes
  familyUserId    String
  familyUser      User   @relation("FamilyContracts", fields: [familyUserId], references: [id])
  caregiverUserId String
  caregiverUser   User   @relation("CaregiverContracts", fields: [caregiverUserId], references: [id])

  // Status
  status ContractStatus @default(DRAFT)

  // Detalhes do Serviço
  title        String?
  description  String?
  tasksJson    String? // Lista de tarefas (JSON array)
  serviceTypes String? // Tipos de serviço (JSON array)

  // Horários
  hoursPerWeek Int?
  scheduleJson String? // Horários detalhados (JSON)

  // Valores
  hourlyRateEur  Int // Taxa por hora em centavos
  totalHours     Int // Total de horas
  totalEurCents  Int // Valor total em centavos
  platformFeePct Int @default(15) // Percentual da plataforma

  // Datas
  startDate DateTime?
  endDate   DateTime?

  // Taxa de contrato
  familyFeePaid    Boolean @default(false)
  caregiverFeePaid Boolean @default(false)

  // Aceite
  acceptedByFamilyAt    DateTime?
  acceptedByCaregiverAt DateTime?

  // Pagamentos
  totalPaidEurCents Int @default(0)

  // Presença
  presenceConfirmationEnabled Boolean @default(false)

  // Weekly Payment System (NEW)
  weeklyPaymentEnabled   Boolean   @default(false) // Toggle para aprovação semanal
  paymentCycleStartDate  DateTime? // Data de início do ciclo de 30 dias
  renewalContractId      String?   // Link para próximo contrato (se renovado)

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
  cancelledAt DateTime?

  // Relations
  acceptance            ContractAcceptance?
  payments              Payment[]
  reviews               Review[]
  presenceConfirmations PresenceConfirmation[] @relation("presenceConfirmations")

  @@index([familyUserId, status])
  @@index([caregiverUserId, status])
  @@index([status, createdAt])
}

model ContractAcceptance {
  id         String   @id @default(cuid())
  contractId String   @unique
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  acceptedByFamilyAt DateTime?
  familyIpAddress    String?
  familyUserAgent    String?

  acceptedByCaregiverAt DateTime?
  caregiverIpAddress    String?
  caregiverUserAgent    String?

  createdAt DateTime @default(now())
}

// ==================== WEEKLY PAYMENT APPROVAL ====================

model WeeklyPaymentApproval {
  id                      String   @id @default(cuid())
  contractId              String

  // Identificação
  weekNumber              Int // 1-4

  // Valores (calculados: totalEurCents / 30 * diasReaisDaSemana)
  weeklyAmountCents       Int // Valor da semana em centavos
  platformFeeCents        Int // Taxa da plataforma
  caregiverAmountCents    Int // O que o cuidador recebe

  // Timeline
  approvalDueAt           DateTime // Prazo para aprovação (ex: sexta 17h)
  createdAt               DateTime @default(now())
  approvedAt              DateTime?
  capturedAt              DateTime?

  // Decisão da Família
  familyDecision          String? // null | "APPROVED" | "DISPUTED"
  familyDecidedAt         DateTime?
  familyNotes             String? // Motivo se disputado

  // Integração Stripe
  stripePaymentHoldId     String? // Link a StripePaymentHold
  familyPaymentId         String? // Link a FamilyPayment
  caregiverTransferId     String? // Link a CaregiverTransfer

  // Status
  status                  String @default("PENDING") // "PENDING" | "APPROVED" | "CAPTURED" | "DISPUTED" | "REFUNDED"

  // Índices para performance
  @@index([contractId, weekNumber])
  @@index([familyDecision, status])
  @@index([approvalDueAt, status])
  @@unique([contractId, weekNumber])
}

// ==================== TIPS (GORJETAS) ====================

// ==================== REVIEWS ====================

model Review {
  id String @id @default(cuid())

  // Contrato e Usuários
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id])
  fromUserId String
  fromUser   User     @relation("ReviewsGiven", fields: [fromUserId], references: [id])
  toUserId   String
  toUser     User     @relation("ReviewsReceived", fields: [toUserId], references: [id])

  // Avaliação
  rating  Int // 1-5
  comment String?

  // Categorias específicas
  punctualityRating     Int? // 1-5
  professionalismRating Int? // 1-5
  communicationRating   Int? // 1-5
  qualityRating         Int? // 1-5

  // Status
  isPublic    Boolean @default(true)
  isModerated Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([toUserId, createdAt])
}

// ==================== CHAT ====================

model ChatRoom {
  id String @id @default(cuid())

  // Tipo de chat
  type String @default("direct") // direct, contract, support

  // Referência (contrato, etc.)
  referenceType String?
  referenceId   String?

  // Status
  isActive Boolean @default(true)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  participants ChatParticipant[]
  messages     ChatMessage[]
}

model ChatParticipant {
  id String @id @default(cuid())

  chatRoomId String
  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Status
  lastReadAt  DateTime?
  unreadCount Int       @default(0)

  createdAt DateTime @default(now())

  @@unique([chatRoomId, userId])
}

model ChatMessage {
  id String @id @default(cuid())

  chatRoomId String
  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation(fields: [senderId], references: [id])

  // Conteúdo
  content     String
  messageType String @default("text") // text, image, file, system

  // Metadata
  metadata String? // JSON (file url, image, etc.)

  // Status
  isEdited  Boolean @default(false)
  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chatRoomId, createdAt])
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Tipo e Conteúdo
  type    String // contract, payment, message, system, etc.
  title   String
  message String

  // Referência
  referenceType String?
  referenceId   String?

  // Status
  isRead Boolean   @default(false)
  readAt DateTime?

  // Entrega
  emailSent Boolean @default(false)
  pushSent  Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt])
}

// ==================== SYSTEM SETTINGS ====================

model PlatformSettings {
  id String @id @default(cuid())

  activationCostEurCents Int @default(3500) // €35
  contractFeeEurCents    Int @default(500) // €5
  platformFeePercent     Int @default(15) // 15%

  updatedAt DateTime @updatedAt
}

// ==================== AUTH (NextAuth) ====================

model Account {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
}

// ==================== INTERVIEWS ====================

model Interview {
  id String @id @default(cuid())

  // Participants
  familyUserId    String
  caregiverUserId String
  contractId      String?

  // Status
  status String @default("SCHEDULED") // SCHEDULED, IN_PROGRESS, COMPLETED, CANCELLED

  // Scheduling
  scheduledAt     DateTime
  durationMinutes Int      @default(30)

  // Video
  videoRoomUrl  String?
  videoProvider String  @default("jitsi")

  // Questionnaire (family fills after interview)
  questionnaireJson String? // JSON with ratings and notes
  familyCompletedAt DateTime?

  // Caregiver feedback (caregiver fills after interview)
  caregiverQuestionnaireJson String?
  caregiverNotes             String?
  caregiverCompletedAt       DateTime?

  // Timestamps
  startedAt DateTime?
  endedAt   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([familyUserId, status])
  @@index([caregiverUserId, status])
}

// ==================== TERMS ACCEPTANCE ====================

model TermsAcceptance {
  id           String   @id @default(cuid())
  userId       String
  termsType    String // terms_of_use, privacy_policy, contract_template, mediation_policy
  termsVersion String   @default("1.0")
  ipAddress    String?
  userAgent    String?
  acceptedAt   DateTime @default(now())

  @@index([userId, termsType])
}

// ==================== GUIDE ACCEPTANCE ====================

// ==================== ESCROW PAYMENTS ====================

model EscrowPayment {
  id              String @id @default(cuid())
  contractId      String
  paymentIntentId String @unique // Stripe PaymentIntent ID

  // Amounts
  totalAmountCents     Int
  platformFeeCents     Int
  caregiverAmountCents Int

  // Status
  status String @default("HELD") // HELD, RELEASED, REFUNDED, PARTIAL_REFUND

  // Stripe Connect
  familyCustomerId   String?
  caregiverAccountId String? // Stripe Connect account
  transferId         String? // Transfer to caregiver
  platformTransferId String? // Transfer to platform

  // Timestamps
  capturedAt DateTime?
  releasedAt DateTime?
  refundedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([contractId])
}

// ==================== ADMIN SYSTEM MODELS ====================

model AdminUser {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role AdminRole @default(ADMIN)

  // Permissions override (JSON)
  customPermissions String? // JSON object for specific permission overrides

  // Access
  isActive          Boolean   @default(true)
  lastAdminActionAt DateTime?

  // Two-Factor Authentication
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  adminActions AdminAction[]

  @@index([role])
  @@index([isActive])
}

model AdminAction {
  id          String    @id @default(cuid())
  adminUserId String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  // Action Details
  action     String // CREATE, UPDATE, DELETE, VIEW, IMPERSONATE, SUSPEND, ACTIVATE, VERIFY_KYC, etc.
  entityType String // USER, CONTRACT, PAYMENT, TOKEN, CAREGIVER, REVIEW, etc.
  entityId   String? // ID of affected entity

  // Data (JSON strings)
  oldValue String? // JSON of previous state
  newValue String? // JSON of new state

  // Context
  ipAddress String?
  userAgent String?
  reason    String? // Required for destructive actions

  createdAt DateTime @default(now())

  @@index([adminUserId, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ==================== SUPPORT TICKETS ====================

model SupportTicket {
  id     String @id @default(cuid())
  userId String

  // Ticket Info
  subject     String
  description String
  category    String @default("general") // general, payment, contract, technical, complaint

  // Status
  status   String @default("open") // open, in_progress, waiting_user, resolved, closed
  priority String @default("normal") // low, normal, high, urgent

  // Assignment
  assignedToId String? // Admin user ID
  assignedAt   DateTime?

  // Resolution
  resolution   String?
  resolvedAt   DateTime?
  resolvedById String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  messages SupportTicketMessage[]

  @@index([userId, status])
  @@index([status, priority])
  @@index([assignedToId])
}

model SupportTicketMessage {
  id       String        @id @default(cuid())
  ticketId String
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  // Sender
  senderId   String // User ID or Admin ID
  senderType String // "user" or "admin"
  senderName String

  // Content
  content     String
  attachments String? // JSON array of file URLs

  // Timestamps
  createdAt DateTime @default(now())

  @@index([ticketId, createdAt])
}

// ==================== RECEIPTS ====================

model Receipt {
  id String @id @default(cuid())

  // Contract and Users
  contractId      String
  familyUserId    String
  caregiverUserId String

  // Receipt Details
  receiptNumber        String   @unique // e.g., "RC-2026-000123"
  periodStart          DateTime
  periodEnd            DateTime
  hoursWorked          Int
  hourlyRateEurCents   Int
  totalAmountCents     Int
  platformFeeCents     Int
  caregiverAmountCents Int

  // Tax info
  familyNif    String?
  caregiverNif String?

  // Status
  status String @default("GENERATED") // GENERATED, SENT, DOWNLOADED

  // Timestamps
  createdAt DateTime @default(now())

  @@index([contractId])
  @@index([familyUserId, createdAt])
  @@index([caregiverUserId, createdAt])
}

// ==================== RECURRING PAYMENTS ====================

model RecurringPayment {
  id String @id @default(cuid())

  contractId      String
  familyUserId    String
  caregiverUserId String

  // Payment details
  amountCents          Int
  platformFeeCents     Int
  caregiverAmountCents Int

  // Billing period
  billingDay  Int       @default(1) // Day of month
  periodStart DateTime
  periodEnd   DateTime?

  // Status
  status         String    @default("ACTIVE") // ACTIVE, PAUSED, CANCELLED
  lastPaymentAt  DateTime?
  nextPaymentAt  DateTime?
  failedAttempts Int       @default(0)

  // Stripe
  stripeSubscriptionId String?
  stripeCustomerId     String?
  stripePriceId        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contractId])
  @@index([status, nextPaymentAt])
}

// ==================== FEATURE FLAGS ====================

// ==================== ADMIN NOTIFICATIONS ====================

model AdminNotification {
  id String @id @default(cuid())

  // Type and Content
  type    String // system, user, contract, payment, alert, etc.
  title   String
  message String

  // Reference
  entityType String? // User, Contract, Payment, etc.
  entityId   String? // ID of related entity

  // Severity
  severity String @default("INFO") // INFO, WARNING, ERROR, CRITICAL

  // Status
  isRead Boolean   @default(false)
  readAt DateTime?
  readBy String? // Admin user ID who read it

  createdAt DateTime @default(now())

  @@index([isRead, createdAt])
  @@index([type, createdAt])
}

// ==================== API KEYS ====================

model ApiKey {
  id String @id @default(cuid())

  // Identification
  name      String // Human-readable name
  keyHash   String @unique // Hashed API key
  keyPrefix String // First 8 chars for identification (e.g., "sk_live_")

  // Permissions
  permissions String? // JSON array of permissions

  // Status
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  expiresAt  DateTime?

  // Owner
  createdBy String // Admin user ID

  createdAt DateTime @default(now())

  @@index([isActive])
  @@index([createdBy])
}

// ==================== EMAIL TEMPLATES ====================

model EmailTemplate {
  id String @id @default(cuid())

  // Identification
  key String @unique // e.g., "welcome", "password_reset", "contract_created"

  // Content
  subject  String // Email subject (can use {{variables}})
  bodyHtml String // HTML body
  bodyText String? // Plain text version (optional)

  // Variables
  variables String? // JSON array of available variables

  // Status
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

// ==================== IMPERSONATION LOGS ====================

model ImpersonationLog {
  id String @id @default(cuid())

  // Participants
  adminUserId  String // Admin who impersonated
  targetUserId String // User being impersonated

  // Reason
  reason String? // Why impersonation was needed

  // Timing
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  durationSeconds Int? // Calculated duration

  // Context
  ipAddress String?
  userAgent String?

  @@index([adminUserId, startedAt])
  @@index([targetUserId, startedAt])
}

// ==================== MODERATION QUEUE ====================

model ModerationQueue {
  id String @id @default(cuid())

  // Entity being moderated
  entityType String // Review, Profile, Message, etc.
  entityId   String // ID of the entity

  // Reporter
  reportedBy String? // User ID who reported (null if system)

  // Reason
  reason String // Why it needs moderation

  // Status
  status String @default("PENDING") // PENDING, REVIEWING, RESOLVED, DISMISSED

  // Resolution
  reviewedBy String? // Admin user ID
  reviewedAt DateTime?
  action     String? // DELETE, WARN, BAN, DISMISS
  notes      String? // Admin notes

  createdAt DateTime @default(now())

  @@index([status, createdAt])
  @@index([entityType, entityId])
}

// ==================== PLATFORM METRICS ====================

model PlatformMetric {
  id String @id @default(cuid())

  // Metric identification
  metricKey   String // e.g., "total_users", "revenue_mtd", "contracts_active"
  metricValue String // Value (stored as string for flexibility)

  // Timing
  computedAt DateTime @default(now())
  period     String? // "daily", "weekly", "monthly", "all_time"

  @@index([metricKey, computedAt])
  @@index([period])
}

// ==================== SCHEDULED REPORTS ====================

model ScheduledReport {
  id String @id @default(cuid())

  // Identification
  name       String // Human-readable name
  reportType String // "users", "revenue", "contracts", "analytics"

  // Schedule
  frequency  String // "daily", "weekly", "monthly"
  recipients String // JSON array of email addresses

  // Configuration
  filters String? // JSON object with filters

  // Execution tracking
  lastRunAt DateTime?
  nextRunAt DateTime?

  // Status
  isActive Boolean @default(true)

  // Owner
  createdBy String // Admin user ID

  createdAt DateTime @default(now())

  @@index([isActive, nextRunAt])
  @@index([createdBy])
}

// ==================== PRESENCE CONFIRMATION ====================

model PresenceConfirmation {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation("presenceConfirmations", fields: [contractId], references: [id], onDelete: Cascade)

  // QR Code Generation
  qrCode        String   @unique // Random token (24h validity)
  qrGeneratedAt DateTime @default(now())
  qrExpiresAt   DateTime // today + 24h

  // Scan Record
  scannedAt       DateTime?
  scannedByUserId String?
  scannedByUser   User?     @relation("PresenceConfirmationScans", fields: [scannedByUserId], references: [id], onDelete: SetNull)

  // Audit Trail
  ipAddress String?
  userAgent String?
  location  String? // GPS coords if available (future)

  // Status
  status String @default("pending") // pending | confirmed | expired

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contractId])
  @@index([qrCode])
  @@index([scannedByUserId])
  @@index([qrExpiresAt])
}

// ==================== DEMANDS (MARKETPLACE) ====================

model Demand {
  id String @id @default(cuid())

  // Criador (Família)
  familyUserId String
  familyUser   User   @relation("DemandFamily", fields: [familyUserId], references: [id], onDelete: Cascade)

  // Conteúdo
  title        String // Ex: "Cuidadora para idosa em Lisboa"
  description  String // Descrição completa (mín. 100 chars)
  serviceTypes String // JSON array de ServiceType

  // Localização
  address    String?
  city       String
  postalCode String?
  country    String  @default("PT")
  latitude   Float?
  longitude  Float?

  // Requisitos
  requiredExperienceLevel ExperienceLevel @default(INTERMEDIATE)
  requiredCertifications  String? // JSON array (CPR, FirstAid, etc)
  careType                CareType        @default(RECURRING)

  // Datas
  desiredStartDate DateTime?
  desiredEndDate   DateTime?
  hoursPerWeek     Int?
  scheduleJson     String? // JSON com horários preferidos

  // Orçamento (Valores em centavos: €100 = 10000)
  budgetEurCents       Int? // Orçamento total que a família pode gastar
  minimumHourlyRateEur Int? // Taxa horária mínima (negociável)

  // Visibilidade
  visibilityPackage   VisibilityPackage @default(NONE)
  visibilityExpiresAt DateTime?

  // Status
  status DemandStatus @default(ACTIVE)

  // Analytics (calculados via API)
  // viewCount: COUNT(DemandView WHERE demandId = X)
  // proposalCount: COUNT(Proposal WHERE demandId = X)
  // visibilitySpent: SUM(VisibilityPurchase.amount WHERE demandId = X)

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime?
  closedReason String?
  deletedAt DateTime?
  deletionReason String?

  // Relations
  demandViews         DemandView[]
  visibilityPurchases VisibilityPurchase[]
  proposals           Proposal[]
  demandNotifications DemandNotification[]
  payments            Payment[]

  @@index([familyUserId, status, createdAt])
  @@index([status, visibilityPackage, visibilityExpiresAt])
  @@index([city, status])
  @@index([createdAt])
}

model DemandView {
  id String @id @default(cuid())

  demandId String
  demand   Demand @relation(fields: [demandId], references: [id], onDelete: Cascade)

  caregiverId String
  caregiver   User   @relation("DemandViewCaregiver", fields: [caregiverId], references: [id], onDelete: Cascade)

  viewedAt DateTime @default(now())

  @@unique([demandId, caregiverId, viewedAt]) // Evitar contagem dupla do mesmo cuidador no mesmo dia
  @@index([demandId, viewedAt])
  @@index([caregiverId, viewedAt])
}

model VisibilityPurchase {
  id String @id @default(cuid())

  demandId String
  demand   Demand @relation(fields: [demandId], references: [id], onDelete: Cascade)

  familyUserId String // Para referência rápida

  package        VisibilityPackage
  amountEurCents Int // Valor em centavos (€3 = 300, €8 = 800, €15 = 1500)

  // Stripe
  stripePaymentIntentId   String?
  stripeCheckoutSessionId String?

  // Status
  status String @default("PENDING") // PENDING, COMPLETED, FAILED, REFUNDED

  purchasedAt DateTime  @default(now())
  expiresAt   DateTime // Package duration
  completedAt DateTime?

  // Metadata
  metadata String? // JSON adicional

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([demandId, status])
  @@index([familyUserId, createdAt])
  @@index([expiresAt])
  @@index([status, completedAt])
}

model DemandNotification {
  id String @id @default(cuid())

  demandId String
  demand   Demand @relation(fields: [demandId], references: [id], onDelete: Cascade)

  caregiverId String
  caregiver   User   @relation("DemandNotifications", fields: [caregiverId], references: [id], onDelete: Cascade)

  // Tipo de notificação
  type String // "new_demand", "demand_updated", "proposal_reminder"

  // Status
  sentAt    DateTime  @default(now())
  readAt    DateTime?
  emailSent Boolean   @default(false)
  pushSent  Boolean   @default(false)

  createdAt DateTime @default(now())

  @@unique([demandId, caregiverId, type, sentAt])
  @@index([caregiverId, readAt])
  @@index([demandId])
}

// ==================== PROPOSALS (para Demandas) ====================

model Proposal {
  id String @id @default(cuid())

  demandId String
  demand   Demand @relation(fields: [demandId], references: [id], onDelete: Cascade)

  caregiverId String
  caregiver   User   @relation("ProposalsGiven", fields: [caregiverId], references: [id], onDelete: Cascade)

  // Conteúdo
  message            String // Mensagem da proposta
  proposedHourlyRate Int? // Taxa horária proposta (em centavos)
  estimatedStartDate DateTime?

  // Status
  status String @default("PENDING") // PENDING, ACCEPTED, REJECTED, EXPIRED

  acceptedAt DateTime?
  rejectedAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([demandId, status])
  @@index([caregiverId, status])
  @@index([createdAt])
}

